# ═══════════════════════════════════════════════════════════════════════════════
# SGR DEV TEST - HYDROGEN STOREFRONT
# Environment Variables Configuration
# ═══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control
# ═══════════════════════════════════════════════════════════════════════════════

# ═══════════════════════════════════════════════════════════════════════════════
# STOREFRONT API CREDENTIALS
# Get from: Shopify Admin > Settings > Apps and sales channels > Develop apps
# ═══════════════════════════════════════════════════════════════════════════════
PUBLIC_STOREFRONT_ID=your_storefront_id
PUBLIC_STOREFRONT_API_TOKEN=your_storefront_api_token
PUBLIC_STORE_DOMAIN=your-store.myshopify.com
PRIVATE_STOREFRONT_API_TOKEN=your_private_storefront_token

# ═══════════════════════════════════════════════════════════════════════════════
# CUSTOMER ACCOUNT API
# Get from: Shopify Admin > Settings > Customer accounts
# ═══════════════════════════════════════════════════════════════════════════════
PUBLIC_CUSTOMER_ACCOUNT_API_CLIENT_ID=your_customer_account_client_id
PUBLIC_CUSTOMER_ACCOUNT_API_URL=https://shopify.com/your_shop_id
SHOP_ID=your_shop_id
SESSION_SECRET=generate_a_random_secret_string

# ═══════════════════════════════════════════════════════════════════════════════
# ADMIN API CREDENTIALS (Required for Wishlist functionality)
# Get from: Shopify Partners Dashboard > Apps > Your App > Configuration
# Required scopes: read_customers, write_customers
# ═══════════════════════════════════════════════════════════════════════════════
SHOPIFY_ADMIN_CLIENT_ID=your_admin_client_id
SHOPIFY_ADMIN_CLIENT_SECRET=your_admin_client_secret

# ═══════════════════════════════════════════════════════════════════════════════
# YOTPO REVIEWS API CREDENTIALS (Required for Reviews functionality)
# Get from: Yotpo Dashboard > Account Settings > API Credentials
# ═══════════════════════════════════════════════════════════════════════════════
YOTPO_APP_KEY=your_yotpo_app_key
YOTPO_SECRET_KEY=your_yotpo_secret_key
YOTPO_ACCOUNT_ID=your_yotpo_account_id
